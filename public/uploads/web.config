<?xml version="1.0" encoding="UTF-8"?>
<!--
  โฟลเดอร์นี้เก็บเฉพาะไฟล์อัปโหลด (static: รูป/เอกสาร) ห้ามรันสคริปต์
  ใช้ requestFiltering ปฏิเสธ request ไปยังนามสกุลที่รันได้ → กัน RCE หากมีไฟล์สคริปต์หลุดเข้ามา
  ใช้ requestFiltering (IIS delegation = Allow) แทน <handlers> (Deny/ล็อก — จะทำให้ทั้งโฟลเดอร์ HTTP 500)
-->
<configuration>
    <system.webServer>
        <security>
            <requestFiltering allowUnlisted="true">
                <fileExtensions>
                    <add fileExtension=".php" allowed="false" />
                    <add fileExtension=".php3" allowed="false" />
                    <add fileExtension=".php4" allowed="false" />
                    <add fileExtension=".php5" allowed="false" />
                    <add fileExtension=".php7" allowed="false" />
                    <add fileExtension=".phtml" allowed="false" />
                    <add fileExtension=".phar" allowed="false" />
                    <add fileExtension=".asp" allowed="false" />
                    <add fileExtension=".aspx" allowed="false" />
                    <add fileExtension=".ashx" allowed="false" />
                    <add fileExtension=".asmx" allowed="false" />
                </fileExtensions>
            </requestFiltering>
        </security>
        <!-- กันรันสคริปต์ผ่าน default document ในโฟลเดอร์นี้ -->
        <defaultDocument enabled="false" />
        <directoryBrowse enabled="false" />
    </system.webServer>
</configuration>
