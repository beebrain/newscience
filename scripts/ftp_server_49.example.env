# ตัวอย่างการตั้งค่า FTP สำหรับ Server 49 (49.231.30.18)
# คัดลอกเป็น ftp_server_49.env แล้วกรอกรหัสผ่าน (อย่า commit ไฟล์ .env)
# ใช้กับ: .\connect_ftp_server_49.ps1

FTP_HOST=49.231.30.18
FTP_PORT=21
FTP_USER=Administrator
# FTP_PASS=ใส่รหัสผ่าน
# IIS site sci.uru.ac.th → C:\inetpub\newscience (ไม่ใช้ sci_root)
FTP_REMOTE_PATH=/newscience
