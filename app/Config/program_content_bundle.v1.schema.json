{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://newscience.local/schema/program_content_bundle.v1.json",
  "title": "Program Content Bundle v1 (3-namespace, no duplication)",
  "description": "เอกสาร JSON นำเข้า/ส่งออก หลักสูตรแบบ 3 namespace (basic/content/settings) — single source per field ไม่มี duplication. รองรับรูปแบบเดิม {program, page} ผ่าน legacy converter ในฝั่ง service",
  "type": "object",
  "required": ["schema_version", "program_id"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1, "maximum": 1 },
    "program_id":     { "type": "integer", "minimum": 1 },
    "exported_at":    { "type": ["string", "null"] },
    "template_note":  { "type": "string" },

    "basic": {
      "description": "ข้อมูลพื้นฐาน — ตาราง programs (editable, single source)",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name_th":        { "type": "string", "maxLength": 500 },
        "name_en":        { "type": "string", "maxLength": 500 },
        "degree_th":      { "type": "string", "maxLength": 500 },
        "degree_en":      { "type": "string", "maxLength": 500 },
        "level":          { "type": "string", "enum": ["", "bachelor", "master", "doctorate"] },
        "credits":        { "type": "integer", "minimum": 0 },
        "duration":       { "type": "integer", "minimum": 0 },
        "description":    { "type": "string", "maxLength": 5000 },
        "description_en": { "type": "string", "maxLength": 5000 },
        "website":        { "type": "string", "maxLength": 500, "pattern": "^(|https?://.+)$" }
      }
    },

    "content": {
      "description": "เนื้อหาหลักสูตร — ตาราง program_pages (เฉพาะ body)",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "philosophy":       { "type": "string", "maxLength": 5000 },
        "objectives": {
          "oneOf": [
            { "type": "array", "items": { "type": ["string", "number"] }, "maxItems": 40 },
            { "type": "string" }
          ]
        },
        "graduate_profile": {
          "oneOf": [
            { "type": "array", "items": { "type": ["string", "number"] }, "maxItems": 40 },
            { "type": "string" }
          ]
        },
        "elos_json":               { "type": ["array", "object", "string", "null"] },
        "learning_standards_json": { "type": ["array", "object", "string", "null"] },
        "curriculum_structure":    { "type": "string", "maxLength": 10000 },
        "study_plan":              { "type": "string", "maxLength": 10000 },
        "curriculum_json":         { "type": ["array", "object", "string", "null"] },
        "careers_json":            { "type": ["array", "string", "null"] },
        "career_prospects":        { "type": "string", "maxLength": 5000 },
        "tuition_fees_json":       { "type": ["array", "string", "null"] },
        "tuition_fees":            { "type": "string", "maxLength": 5000 },
        "admission_info":          { "type": "string", "maxLength": 5000 },
        "contact_info":            { "type": "string", "maxLength": 5000 },
        "intro_video_url":         { "type": "string", "maxLength": 500 },
        "alumni_messages_json":    { "type": ["array", "object", "string", "null"] }
      }
    },

    "settings": {
      "description": "การตั้งค่า UI + เผยแพร่ — ตาราง program_pages",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "slug":             { "type": "string", "maxLength": 500 },
        "hero_image":       { "type": "string", "maxLength": 500 },
        "theme_color":      { "type": "string", "pattern": "^(|#[0-9A-Fa-f]{6})$" },
        "text_color":       { "type": ["string", "null"], "pattern": "^(|#[0-9A-Fa-f]{6})$" },
        "background_color": { "type": ["string", "null"], "pattern": "^(|#[0-9A-Fa-f]{6})$" },
        "meta_description": { "type": "string", "maxLength": 500 },
        "gallery_images":   { "type": ["array", "string", "null"] },
        "social_links":     { "type": ["array", "object", "string", "null"] },
        "is_published":     { "type": ["boolean", "integer"], "minimum": 0, "maximum": 1 }
      }
    }
  }
}
