#--------------------------------------------------------------------
# Production Environment Configuration
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'https://sci.uru.ac.th/'
app.indexPage = 'index.php'
app.appTimezone = 'Asia/Bangkok'
app.defaultLocale = 'th'
app.negotiateLocale = true
app.supportedLocales = ['en', 'th']

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = newscience
database.default.username = root
database.default.password = <CHANGE_ME_DB_PASSWORD>
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

encryption.key = 'Your32CharacterEncryptionKeyHere!!'

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
session.savePath = WRITEPATH . 'session'

#--------------------------------------------------------------------
# EMAIL (Config\Email — E-Certificate และอีเมลระบบ)
#--------------------------------------------------------------------

email.fromEmail = 'noreply@sci.uru.ac.th'
email.fromName = 'คณะวิทยาศาสตร์และเทคโนโลยี มหาวิทยาลัยราชภัฏอุตรดิตถ์'

email.protocol = smtp
email.SMTPHost = smtp.example.com
email.SMTPUser = 
email.SMTPPass = 
email.SMTPPort = 587
email.SMTPTimeout = 30
email.SMTPKeepAlive = false
email.SMTPCrypto = tls

email.mailType = text
email.charset = UTF-8
email.wordWrap = true
email.wrapChars = 76
email.validate = false
email.priority = 3

email.BCCBatchMode = false
email.BCCBatchSize = 200
email.DSN = false

#--------------------------------------------------------------------
# SSO CONFIGURATION
#--------------------------------------------------------------------

edocsso.baseUrl = "https://edoc.sci.uru.ac.th/public"
edocsso.exchangeCodeUrl = "https://edoc.sci.uru.ac.th/public/index.php/api/sso/exchange-code"
edocsso.sharedSecret = "<CHANGE_ME_SHARED_SECRET>"
edocsso.enabled = true

researchrecordsso.baseUrl = "https://sci.uru.ac.th/recordresearch"
researchrecordsso.sharedSecret = "<CHANGE_ME_SHARED_SECRET>"
researchrecordsso.enabled = true
researchrecordsso.logoutUrl = "https://sci.uru.ac.th/recordresearch/index.php/logout"
researchrecordsso.logoutReturnParam = "return_url"
researchrecordsso.ssoEntryPath = "/index.php/auth/sso-entry"

RESEARCH_API_BASE_URL = https://sci.uru.ac.th/recordresearch/index.php
