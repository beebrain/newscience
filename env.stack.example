# คัดลอกเป็น `.env` ที่ root โปรเจกต์ (ข้าง app/) — ชื่อต้องเป็น `.env` เท่านั้น
# CodeIgniter 4 จะไม่อ่านไฟล์ชื่อ `env` (ไม่มีจุดนำหน้า)
#
# อย่า commit ไฟล์ `.env` — อย่าวางรหัสผ่านจริงในแชทสาธารณะ

CI_ENVIRONMENT = development

app.baseURL = 'http://localhost/newscience/public/'
app.indexPage = ''
app.appTimezone = 'Asia/Bangkok'

# --- แอปหลัก (หน้าเว็บ / API ผ่าน shared_php + shared_mysql) ---
# จากใน container ใช้ชื่อบริการ shared_mysql (ไม่ใช้ 127.0.0.1)
# จากเครื่อง host (mysql CLI นอก Docker): hostname = 127.0.0.1, password = rootpass
database.default.hostname = shared_mysql
database.default.database = newscience
database.default.username = root
database.default.password = rootpass
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_unicode_ci

# --- สำหรับสคริปต์ที่เทียบ/โคลนจาก server (database.server.*) ---
database.server.hostname = example.uru.ac.th
database.server.database = newscience
database.server.username = root
database.server.password = 'CHANGE_ME'
database.server.DBDriver = MySQLi
database.server.DBPrefix =
database.server.port = 3306

# --- sci-edoc บน server / บนเครื่อง (spark import / analyze) ---
database.edocserver.hostname = edoc.example.ac.th
database.edocserver.database = sci-edoc
database.edocserver.username = sci-edoc
database.edocserver.password = 'CHANGE_ME'
database.edocserver.DBDriver = MySQLi
database.edocserver.DBPrefix =
database.edocserver.port = 3306

database.edoclocal.hostname = 127.0.0.1
database.edoclocal.database = sci-edoc
database.edoclocal.username = root
database.edoclocal.password = ''
database.edoclocal.DBDriver = MySQLi
database.edoclocal.DBPrefix =
database.edoclocal.port = 3306

# encryption.key ต้องเป็น hex คู่จำนวนตัว (64 ตัว = 32 byte) หลัง hex2bin:
encryption.key = hex2bin:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

cookie.secure = false
session.driver = 'CodeIgniter\Session\Handlers\FileHandler'

logger.threshold = 9

uruoauth.enabled = false
